{
  "name": "insitu-frontend",
  "description": "A Volto-powered Plone frontend",
  "license": "MIT",
  "version": "2.39.0",
  "scripts": {
    "postinstall": "make omelette && make patches",
    "start": "razzle start",
    "build": "razzle build --noninteractive",
    "lint": "./node_modules/eslint/bin/eslint.js --max-warnings=0 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:fix": "./node_modules/eslint/bin/eslint.js --fix 'src/**/*.{js,jsx,ts,tsx}'",
    "lint:ci": "./node_modules/eslint/bin/eslint.js --max-warnings=0 -f checkstyle 'src/**/*.{js,jsx,ts,tsx}' > eslint.xml",
    "prettier": "./node_modules/.bin/prettier --single-quote --check 'src/**/*.{js,jsx,ts,tsx,css,scss}'",
    "prettier:fix": "./node_modules/.bin/prettier --single-quote --write 'src/**/*.{js,jsx,ts,tsx,css,scss}'",
    "prettier:ci": "./node_modules/.bin/prettier --single-quote --check 'src/**/*.{js,jsx,ts,tsx,css,scss}'",
    "stylelint": "stylelint 'theme/**/*.{css,scss,less}' 'src/**/*.{css,scss,less}' --allow-empty-input",
    "stylelint:overrides": "stylelint 'theme/**/*.overrides' 'src/**/*.overrides' --allow-empty-input",
    "stylelint:fix": "yarn stylelint --fix && yarn stylelint:overrides --fix",
    "test": "razzle test --passWithNoTests",
    "typecheck": "tsc --project tsconfig.json --noEmit",
    "cypress:open": "make test-acceptance",
    "cypress:run": "test-acceptance-headless",
    "start:prod": "NODE_ENV=production node build/server.js",
    "i18n": "rm -rf build/messages && NODE_ENV=production i18n",
    "storybook": "start-storybook -p 6006",
    "build-storybook": "build-storybook"
  },
  "private": true,
  "workspaces": [
    "src/addons/*"
  ],
  "theme": "@eeacms/volto-insitu-policy",
  "addons": [
    "@eeacms/volto-eea-kitkat",
    "@eeacms/volto-embed",
    "@eeacms/volto-embed-static-content",
    "@eeacms/volto-embed-content",
    "@eeacms/volto-tableau",
    "@eeacms/volto-datablocks",
    "@eeacms/volto-eea-map",
    "@eeacms/volto-plotlycharts",
    "@eeacms/volto-block-data-figure",
    "@eeacms/volto-block-toc",
    "@eeacms/volto-globalsearch",
    "@eeacms/volto-searchlib",
    "@eeacms/volto-chatbot",
    "@eeacms/volto-eea-design-system",
    "@eeacms/volto-eea-website-theme",
    "@eeacms/volto-insitu-policy",
    "@plone-collective/volto-authomatic"
  ],
  "resolutions": {
    "@elastic/search-ui": "1.21.2",
    "@eeacms/volto-embed": "11.0.4",
    "@eeacms/volto-embed-content": "1.0.2",
    "@eeacms/volto-embed-static-content": "1.0.4",
    "@eeacms/volto-eea-kitkat": "33.0.7",
    "@eeacms/volto-datablocks": "8.0.3",
    "@eeacms/volto-eea-design-system": "1.60.8",
    "@eeacms/volto-eea-website-theme": "4.3.8",
    "@eeacms/volto-eea-map": "6.0.1",
    "@eeacms/volto-block-data-figure": "9.0.2",
    "@eeacms/volto-plotlycharts": "14.0.6",
    "@eeacms/volto-tableau": "9.0.4",
    "@eeacms/volto-globalsearch": "4.0.1",
    "@eeacms/volto-searchlib": "4.1.0",
    "@eeacms/volto-chatbot": "^0.6.1",
    "@eeacms/volto-citation": "2.0.1",
    "@eeacms/volto-datahub": "3.0.2",
    "@eeacms/volto-design-tokens": "2.0.1",
    "@eeacms/volto-editing-progress": "3.0.1",
    "@eeacms/volto-eea-versions": "2.0.1",
    "@eeacms/volto-redmine-helpdesk": "2.0.1",
    "@eeacms/volto-workflow-progress": "6.0.1",
    "@plone-collective/volto-authomatic": "2.0.1",
    "@eeacms/volto-description-block": "3.0.1",
    "volto-subsites": "4.0.0",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "d3-array": "^2.12.1",
    "react-colorscales": "github:eea/react-colorscales#1.0.2",
    "react-dev-utils": "^12",
    "react-error-overlay": "6.0.9",
    "react-is": "^18.2.0",
    "react-refresh": "0.14.0",
    "eslint-plugin-jsx-a11y": "6.7.1",
    "eslint-plugin-react-hooks": "4.6.0",
    "request/form-data": "2.5.4",
    "sane/execa": "2.0.0",
    "shell-quote": "1.7.3",
    "webpack-bundle-analyzer": "4.10.1"
  },
  "dependencies": {
    "@eeacms/volto-block-data-figure": "9.0.2",
    "@eeacms/volto-block-toc": "9.0.1",
    "@eeacms/volto-chatbot": "0.6.1",
    "@eeacms/volto-datablocks": "8.0.3",
    "@eeacms/volto-eea-design-system": "1.60.8",
    "@eeacms/volto-eea-kitkat": "33.0.7",
    "@eeacms/volto-eea-map": "6.0.1",
    "@eeacms/volto-eea-website-theme": "4.3.8",
    "@eeacms/volto-embed": "11.0.4",
    "@eeacms/volto-embed-content": "1.0.2",
    "@eeacms/volto-embed-static-content": "1.0.4",
    "@eeacms/volto-globalsearch": "4.0.1",
    "@eeacms/volto-insitu-policy": "0.1.54",
    "@eeacms/volto-plotlycharts": "14.0.6",
    "@eeacms/volto-searchlib": "4.1.0",
    "@eeacms/volto-tableau": "9.0.4",
    "@plone-collective/volto-authomatic": "2.0.1",
    "@plone/volto": "18.35.0"
  },
  "devDependencies": {
    "@babel/eslint-parser": "7.28.6",
    "@babel/plugin-proposal-export-namespace-from": "7.18.9",
    "@babel/plugin-proposal-json-strings": "7.18.6",
    "@babel/plugin-proposal-throw-expressions": "7.18.6",
    "@babel/plugin-syntax-export-namespace-from": "7.8.3",
    "@cypress/code-coverage": "3.10.0",
    "@fiverr/afterbuild-webpack-plugin": "^1.0.0",
    "@loadable/babel-plugin": "5.13.2",
    "@loadable/webpack-plugin": "5.15.2",
    "@plone/scripts": "^3.3.2",
    "@storybook/addon-actions": "^6.3.0",
    "@storybook/addon-controls": "6.3.0",
    "@storybook/addon-essentials": "^6.3.0",
    "@storybook/addon-links": "^6.3.0",
    "@storybook/builder-webpack5": "^6.5.15",
    "@storybook/manager-webpack5": "^6.5.15",
    "@storybook/react": "^6.3.0",
    "@testing-library/jest-dom": "5.17.0",
    "@testing-library/react": "14.3.1",
    "@typescript-eslint/eslint-plugin": "6.7.0",
    "@typescript-eslint/parser": "6.7.0",
    "babel-loader": "9.1.0",
    "babel-plugin-add-module-exports": "0.2.1",
    "babel-plugin-lodash": "3.3.4",
    "babel-plugin-root-import": "6.1.0",
    "brotli-webpack-plugin": "1.1.0",
    "bundlewatch": "0.3.3",
    "circular-dependency-plugin": "5.2.2",
    "compression-webpack-plugin": "10.0.0",
    "css-loader": "5.2.7",
    "cypress-fail-fast": "7.0.0",
    "eslint": "8.57.1",
    "eslint-config-prettier": "9.1.2",
    "eslint-config-react-app": "7.0.1",
    "eslint-import-resolver-alias": "1.1.2",
    "eslint-import-resolver-babel-plugin-root-import": "1.1.1",
    "eslint-plugin-no-only-tests": "3.4.0",
    "eslint-plugin-prettier": "^5.1.3",
    "html-webpack-plugin": "5.5.0",
    "identity-obj-proxy": "3.0.0",
    "jest-file": "1.0.0",
    "jest-junit": "16.0.0",
    "less": "3.11.1",
    "less-loader": "11.1.0",
    "lodash-webpack-plugin": "0.11.6",
    "mini-css-extract-plugin": "2.7.2",
    "moment-locales-webpack-plugin": "1.2.0",
    "mrs-developer": "*",
    "postcss": "8.4.31",
    "postcss-overrides": "3.1.4",
    "prettier": "3.0.3",
    "razzle": "4.2.18",
    "razzle-dev-utils": "4.2.18",
    "style-loader": "3.3.1",
    "stylelint": "15.10.3",
    "stylelint-config-idiomatic-order": "9.0.0",
    "stylelint-prettier": "4.0.2",
    "svg-loader": "0.0.2",
    "svgo-loader": "3.0.3",
    "terser-webpack-plugin": "5.3.6",
    "ts-jest": "^26.4.2",
    "ts-loader": "9.4.4",
    "typescript": "5.2.2",
    "webpack": "5.105.4",
    "webpack-dev-server": "4.11.1",
    "webpack-node-externals": "3.0.0"
  },
  "jest": {
    "modulePathIgnorePatterns": [
      "api"
    ],
    "transform": {
      "^.+\\.js(x)?$": "babel-jest",
      "^.+\\.ts(x)?$": "babel-jest",
      "^.+\\.(png)$": "jest-file",
      "^.+\\.(jpg)$": "jest-file",
      "^.+\\.(svg)$": "./node_modules/@plone/volto/jest-svgsystem-transform.js"
    },
    "transformIgnorePatterns": [
      "/node_modules/(?!(@plone/volto|@plone/registry|@plone/volto-slate)).+\\.js$"
    ],
    "moduleNameMapper": {
      "@plone/volto/cypress/(.*)$": "<rootDir>/node_modules/@plone/volto/cypress/$1",
      "@plone/volto/addon-registry": "<rootDir>/node_modules/@plone/registry/addon-registry",
      "@plone/registry/addon-registry": "<rootDir>/node_modules/@plone/registry/addon-registry",
      "@plone/volto/webpack-plugins/webpack-less-plugin": "<rootDir>/node_modules/@plone/volto/webpack-plugins/webpack-less-plugin",
      "@plone/volto/babel": "<rootDir>/node_modules/@plone/volto/babel",
      "@plone/volto/(.*)$": "<rootDir>/node_modules/@plone/volto/src/$1",
      "@plone/volto-slate/(.*)$": "<rootDir>/node_modules/@plone/volto-slate/src/$1",
      "@eeacms/volto-listing-block/messages": "<rootDir>/node_modules/@eeacms/volto-listing-block/src/messages",
      "@eeacms/volto-insitu-policy/\\.\\./theme/(.*)$": "<rootDir>/src/addons/volto-insitu-policy/theme/$1",
      "@eeacms/volto-insitu-policy/(.*)$": "<rootDir>/src/addons/volto-insitu-policy/src/$1",
      "load-volto-addons": "<rootDir>/node_modules/@plone/volto/jest-addons-loader.js",
      "@package/(.*)$": "<rootDir>/src/$1",
      "@root/(.*)$": "<rootDir>/src/$1",
      "~/(.*)$": "<rootDir>/src/$1",
      "\\.(css|less|scss|sass)$": "identity-obj-proxy"
    },
    "coverageThreshold": {
      "global": {
        "branches": 10,
        "functions": 10,
        "lines": 10,
        "statements": 10
      }
    },
    "setupFiles": [
      "<rootDir>/src/jest-setup.js",
      "@plone/volto/test-setup-globals.js",
      "@plone/volto/test-setup-config.jsx"
    ],
    "globals": {
      "__DEV__": true
    }
  },
  "prettier": {
    "trailingComma": "all",
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.overrides",
        "options": {
          "parser": "less"
        }
      }
    ]
  },
  "stylelint": {
    "extends": [
      "stylelint-config-idiomatic-order"
    ],
    "plugins": [
      "stylelint-prettier"
    ],
    "overrides": [
      {
        "files": [
          "**/*.less"
        ],
        "customSyntax": "postcss-less"
      },
      {
        "files": [
          "**/*.overrides"
        ],
        "customSyntax": "postcss-less"
      }
    ],
    "rules": {
      "prettier/prettier": true,
      "rule-empty-line-before": [
        "always-multi-line",
        {
          "except": [
            "first-nested"
          ],
          "ignore": [
            "after-comment"
          ]
        }
      ]
    },
    "ignoreFiles": "theme/themes/default/**/*.overrides"
  },
  "browserslist": [
    ">1%",
    "last 4 versions",
    "Firefox ESR",
    "not ie 11",
    "not dead"
  ],
  "engines": {
    "node": "^20 || ^22"
  },
  "packageManager": "yarn@3.2.3"
}
